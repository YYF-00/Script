#!/bin/sh

TARGET_IP="192.168.50.5"
MAC_ADDRESS="22:31:6C:04:0D:4B"
INTERFACE="br0"

# 1. 发送第一次唤醒包
/usr/sbin/ether-wake -i "$INTERFACE" "$MAC_ADDRESS"

# 2. 开始循环探测（总计尝试 30 次，每次间隔 3 秒，总计约 90 秒）
COUNT=0
MAX_ATTEMPTS=30

while [ $COUNT -lt $MAX_ATTEMPTS ]; do
    # 使用 -t 1 (或 -W 1) 快速探测，减少单次卡顿时间
    if ping -c 1 -W 1 "$TARGET_IP" > /dev/null 2>&1; then
        echo "PVE Boot Success"
        exit 0
    fi

    # 优化点：在第 5 次和第 10 次循环时，如果还没亮，补发一次 WOL 包，防止丢包
    if [ $COUNT -eq 5 ] || [ $COUNT -eq 10 ]; then
        /usr/sbin/ether-wake -i "$INTERFACE" "$MAC_ADDRESS"
    fi

    sleep 3
    COUNT=$((COUNT+1))
done

# 3. 确实超时了
echo "PVE Boot Timeout"
exit 1