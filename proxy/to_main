#!/bin/bash

set -e

MAIN_GW="192.168.50.1"

echo "================================================"
echo "[TO_MAIN] 恢复主路由"
echo "================================================"

########################################
# 获取 SSH IP
########################################

USER_IP=$(echo $SSH_CLIENT | awk '{print $1}')

########################################
# 恢复网关
########################################

echo
echo "[1] 恢复默认网关"

ip route replace default via $MAIN_GW

########################################
# 删除 SSH 特殊路由
########################################

if [ -n "$USER_IP" ]; then

    if [[ ! "$USER_IP" =~ ^192\.168\.50\. ]]; then

        echo
        echo "[2] 删除 SSH 锁定"

        ip route del $USER_IP via $MAIN_GW 2>/dev/null || true
    fi
fi

########################################
# 恢复 DNS
########################################

echo
echo "[3] 恢复 DNS"

if [ -f /etc/resolv.conf.bak ]; then
    cp /etc/resolv.conf.bak /etc/resolv.conf
else
    cat >/etc/resolv.conf <<EOF
nameserver 223.5.5.5
nameserver 1.1.1.1
EOF
fi

########################################
# 当前路由
########################################

echo
echo "[4] 当前路由"

ip route

########################################
# 当前出口
########################################

echo
echo "[5] 当前出口 IP"

curl -s myip.ipip.net || true

echo
echo "================================================"
echo "[TO_MAIN] 完成"
echo "================================================"